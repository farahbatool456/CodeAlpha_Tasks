# .gitignore
# Files and folders to exclude from GitHub

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environment ──────────────────────────────────
venv/
env/
.venv/
ENV/

# ── IDE Files ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Streamlit Cache ──────────────────────────────────────
.streamlit/

# ── Jupyter Notebooks (if any) ──────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment Variables ────────────────────────────────
.env
.env.local

# ── NLTK Data (large, downloaded automatically) ─────────
# nltk_data/   ← uncomment if you store NLTK data locally

# ── Logs ────────────────────────────────────────────────
*.log
logs/

# ── Temporary Files ──────────────────────────────────────
*.tmp
*.bak
*.orig

# ── OS Generated ─────────────────────────────────────────
.DS_Store
Desktop.ini
